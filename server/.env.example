# Environment variables for SyncSphere Server

# Port for the Express/Socket.io server
PORT=3001

# PostgreSQL Database Connection URL (Prisma)
# Replace with your actual PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/syncsphere?schema=public"

# JWT Secret for User Authentication
# Must be at least 32 characters long in production
JWT_SECRET="development_secret_key_change_me_in_production"
